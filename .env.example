# Groq API Configuration
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI Base URL (for proxy or alternative endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Alternatively, use the GUI settings panel (start the server first) or:
#   python cli.py settings --set-groq-key
#   python cli.py settings --set-openai-key

# Optional: Dual local transcription merge credentials
# Used when --dual-local and --merge-use-ai are enabled.
# Falls back to OPENAI_* credentials if not set.
# MERGE_API_KEY=your_merge_api_key_here
# MERGE_BASE_URL=https://api.openai.com/v1
# MERGE_MODEL=gpt-4o

# Server Configuration (Optional)
HOST=0.0.0.0
PORT=8001
